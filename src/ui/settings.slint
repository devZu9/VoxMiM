import { CheckBox, HorizontalBox, VerticalBox, LineEdit, ComboBox } from "std-widgets.slint";

export component SettingsWindow inherits Window {
    in-out property <bool> engine-server;
    in-out property <bool> det-server;
    in-out property <bool> use-gpu;
    in-out property <bool> wake-enable;
    in-out property <string> wake-words;
    in-out property <bool> vad-enable;
    in-out property <int> vad-aggr;
    in-out property <string> vad-timeout;
    in-out property <bool> fix-hallucinations;
    in-out property <bool> fix-user-dict;
    in-out property <bool> fix-repetitions;
    in-out property <bool> fix-punctuation;
    in-out property <string> cmd-max-words;
    in-out property <bool> math-mode;
    in-out property <bool> noise-filter;
    in-out property <bool> warmup;
    in-out property <bool> show-result;
    in-out property <bool> log-enable;
    in-out property <string> log-dir;
    in-out property <bool> trailing-space;
    in-out property <int> cur-lang;
    in-out property <bool> dark-mode;
    callback apply();

    title: "VoxMiM — Настройки";
    preferred-width: 520px;
    preferred-height: 500px;

    property <int> cur-tab: 0;

    // Цвета
    property <color> tab-bg-active: dark-mode ? #3366aa : #4488ee;
    property <color> tab-bg: dark-mode ? #555555 : #666666;

    VerticalLayout { spacing: 0px;
        // Tab buttons
        HorizontalLayout { spacing: 0px;
            Rectangle { width: 110px; height: 28px; background: cur-tab == 0 ? tab-bg-active : tab-bg;
                TouchArea { clicked => { cur-tab = 0; } }
                Text { text: "Основные"; color: white; horizontal-alignment: center; vertical-alignment: center; }
            }
            Rectangle { width: 90px; height: 28px; background: cur-tab == 1 ? tab-bg-active : tab-bg;
                TouchArea { clicked => { cur-tab = 1; } }
                Text { text: "Запись"; color: white; horizontal-alignment: center; vertical-alignment: center; }
            }
            Rectangle { width: 80px; height: 28px; background: cur-tab == 2 ? tab-bg-active : tab-bg;
                TouchArea { clicked => { cur-tab = 2; } }
                Text { text: "Текст"; color: white; horizontal-alignment: center; vertical-alignment: center; }
            }
            Rectangle { width: 80px; height: 28px; background: cur-tab == 3 ? tab-bg-active : tab-bg;
                TouchArea { clicked => { cur-tab = 3; } }
                Text { text: "Прочее"; color: white; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
        // Tab content
        VerticalLayout { padding: 12px; spacing: 6px;
            if (cur-tab == 0) : VerticalLayout { spacing: 6px;
                Text { font-size: 14px; font-weight: 700; text: "Режим транскрайбера:"; }
                HorizontalLayout { spacing: 12px;
                    CheckBox { text: "One-shot"; checked: !engine-server; }
                    CheckBox { text: "Сервер"; checked <=> engine-server; toggled => { apply(); } }
                }
                Text { text: "Режим детектора:"; }
                HorizontalLayout { spacing: 12px;
                    CheckBox { text: "One-shot"; checked: !det-server; }
                    CheckBox { text: "Сервер"; checked <=> det-server; toggled => { apply(); } }
                }
                CheckBox { text: "GPU"; checked <=> use-gpu; toggled => { apply(); } }
                Text { text: "Язык интерфейса:"; }
                ComboBox { model: ["Русский", "English"]; current-index <=> cur-lang; }
            }
            if (cur-tab == 1) : VerticalLayout { spacing: 6px;
                CheckBox { text: "Голосовая активация"; checked <=> wake-enable; toggled => { apply(); } }
                Text { text: "Фразы (по одной на строке):"; }
                LineEdit { text <=> wake-words; }
                CheckBox { text: "Автостоп (VAD)"; checked <=> vad-enable; toggled => { apply(); } }
                HorizontalLayout { spacing: 6px;
                    Text { text: "Агрессивность:"; }
                    ComboBox { model: ["0", "1", "2", "3"]; current-index: vad-aggr; }
                }
                HorizontalLayout { spacing: 6px;
                    Text { text: "Таймаут тишины:"; }
                    LineEdit { text <=> vad-timeout; }
                    Text { text: "сек"; }
                }
            }
            if (cur-tab == 2) : VerticalLayout { spacing: 6px;
                CheckBox { text: "Удаление галлюцинаций"; checked <=> fix-hallucinations; toggled => { apply(); } }
                CheckBox { text: "Пользовательский словарь"; checked <=> fix-user-dict; toggled => { apply(); } }
                CheckBox { text: "Схлопывание повторов"; checked <=> fix-repetitions; toggled => { apply(); } }
                CheckBox { text: "Пунктуация"; checked <=> fix-punctuation; toggled => { apply(); } }
                HorizontalLayout { spacing: 6px;
                    Text { text: "Макс. слов для команд:"; }
                    LineEdit { text <=> cmd-max-words; }
                }
            }
            if (cur-tab == 3) : VerticalLayout { spacing: 6px;
                CheckBox { text: "Math Mode"; checked <=> math-mode; toggled => { apply(); } }
                CheckBox { text: "Шумоподавление"; checked <=> noise-filter; toggled => { apply(); } }
                CheckBox { text: "Прогрев при старте"; checked <=> warmup; toggled => { apply(); } }
                CheckBox { text: "Показывать результат"; checked <=> show-result; toggled => { apply(); } }
                CheckBox { text: "Логирование"; checked <=> log-enable; toggled => { apply(); } }
                Text { text: "Папка логов:"; }
                LineEdit { text <=> log-dir; }
                CheckBox { text: "Пробел в конце"; checked <=> trailing-space; toggled => { apply(); } }
                CheckBox { text: "Тёмная тема"; checked <=> dark-mode; toggled => { apply(); } }
            }
        }
    }
}
